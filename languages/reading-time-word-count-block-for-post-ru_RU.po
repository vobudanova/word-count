#: admin/class-reading-time-word-count-block-post-admin.php
msgid "Reading Time and Word Count"
msgstr "Время чтения и количество слов"

#: admin/class-reading-time-word-count-block-post-admin.php
msgid "Reading Time"
msgstr "Время чтения"

#: admin/class-reading-time-word-count-block-post-admin.php
msgid "Settings"
msgstr "Настройки"

#: admin/class-reading-time-word-count-block-post-admin.php
msgid "Save settings?"
msgstr "Сохранить настройки?"

#: admin/class-reading-time-word-count-block-post-admin.php
msgid "You do not have permission to perform this action."
msgstr "У вас нет прав на это действие."

#: admin/class-reading-time-word-count-block-post-admin.php
msgid "Invalid security token."
msgstr "Недействительный токен безопасности."

#: admin/class-reading-time-word-count-block-post-admin.php
msgid "Settings saved successfully."
msgstr "Настройки успешно сохранены."

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "Reading Time and Word Count Settings"
msgstr "Настройки времени чтения и количества слов"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "Choose what to show in each location. Individual posts and pages can override this in the editor."
msgstr "Выберите, что показывать в каждом месте. Для отдельных записей и страниц это можно переопределить в редакторе."

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "After the post title"
msgstr "После заголовка поста"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "On a single post page, right after its title."
msgstr "На странице одиночного поста, сразу после заголовка."

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "In the post body"
msgstr "В теле поста"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "On a single post page, before the main text."
msgstr "На странице одиночного поста, перед основным текстом."

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "In the page body"
msgstr "В теле страницы"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "On a single page, before the main text."
msgstr "На одиночной странице, перед основным текстом."

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "In listings and archives"
msgstr "В списках и архивах"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "On the home page, archives and search, before each post excerpt."
msgstr "На главной, в архивах и поиске — перед анонсом каждого поста."

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "In related posts"
msgstr "В связанных постах"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "Next to post titles rendered inside secondary loops (e.g. a “Related posts” widget)."
msgstr "Рядом с заголовками записей во вложенных циклах (например, виджет «Похожие записи»)."

#: admin/partials/reading-time-word-count-block-post-admin-display.php
#: admin/partials/reading-time-word-count-block-post-metabox.php
msgid "Do not show"
msgstr "Не показывать"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
#: admin/partials/reading-time-word-count-block-post-metabox.php
msgid "Reading time only"
msgstr "Только время чтения"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
#: admin/partials/reading-time-word-count-block-post-metabox.php
msgid "Word count only"
msgstr "Только количество слов"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
#: admin/partials/reading-time-word-count-block-post-metabox.php
msgid "Reading time + word count"
msgstr "Время чтения + количество слов"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "Save Changes"
msgstr "Сохранить изменения"

#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "Note:"
msgstr "Примечание:"

#. translators: %s: the [reading_time] shortcode wrapped in a <code> tag.
#: admin/partials/reading-time-word-count-block-post-admin-display.php
msgid "you can also insert the block manually via the %s shortcode."
msgstr "также можно вставить блок вручную через шорткод %s."

#: admin/partials/reading-time-word-count-block-post-metabox.php
msgid "Reading-time block for this post:"
msgstr "Блок времени чтения для этой записи:"

#: admin/partials/reading-time-word-count-block-post-metabox.php
msgid "Default (use global settings)"
msgstr "По умолчанию (использовать глобальные настройки)"

#. translators: %s: reading time in minutes.
#: public/partials/reading-time-word-count-block-post-public-display.php
msgid "%s min read"
msgstr "%s мин."

#. translators: %s: number of words.
#: public/partials/reading-time-word-count-block-post-public-display.php
msgid "%s word"
msgid_plural "%s words"
msgstr[0] "%s слово"
msgstr[1] "%s слова"
msgstr[2] "%s слов"
